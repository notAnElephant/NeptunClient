{
  "name": "neptun-companion",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "expo-widgets"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:personal": "EXPO_PUBLIC_DISABLE_IOS_WIDGET=true expo prebuild --clean --platform ios && EXPO_PUBLIC_DISABLE_IOS_WIDGET=true expo run:ios",
    "web": "expo start --web",
    "distribute:android": "./scripts/distribute-android.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@expo/ui": "~57.0.7",
    "@expo/vector-icons": "^15.1.1",
    "@posthog/react-native-plugin": "^2.2.3",
    "@tanstack/react-query": "^5.101.2",
    "expo": "^57.0.7",
    "expo-application": "~57.0.2",
    "expo-constants": "^57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-device": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-linking": "^57.0.3",
    "expo-localization": "~57.0.1",
    "expo-router": "^57.0.7",
    "expo-secure-store": "^57.0.1",
    "expo-sqlite": "^57.0.1",
    "expo-status-bar": "^57.0.1",
    "expo-widgets": "~57.0.6",
    "posthog-react-native": "^4.56.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-android-widget": "0.21.0",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
