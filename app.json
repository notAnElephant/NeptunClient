{
  "expo": {
    "name": "Neptun",
    "slug": "neptunclient",
    "scheme": "neptuncompanion",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "hu.neptun.companion"
    },
    "android": {
      "package": "hu.neptun.companion"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "A Neptun munkamenet védelme"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb6432dc-cf52-4fc5-ac4b-dcf31c2a6282"
      }
    },
    "owner": "notanelephants-team"
  }
}
